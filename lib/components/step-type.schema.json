{
  "id": "step-type",
  "name": "Workflow Step",
  "description": "Document a step in a workflow process",
  "icon": "M3 6l3 3l6-6",
  "fields": [
    { "key": "name", "label": "Name", "type": "text", "required": true, "defaultValue": "Step" },
    { "key": "category", "label": "Category", "type": "select", "options": ["sync", "async"], "defaultValue": "sync" },
    { "key": "description", "label": "Description", "type": "textarea" },
    {
      "key": "properties",
      "label": "Properties",
      "type": "textarea",
      "description": "YAML array of properties. Each: name, type, required, description"
    },
    { "key": "example", "label": "Config example", "type": "textarea" }
  ],
  "display": {
    "color": "var(--type-api)",
    "layout": "badge",
    "summaryField": "name",
    "summaryFallback": "Unnamed step",
    "badgeField": "category"
  }
}
