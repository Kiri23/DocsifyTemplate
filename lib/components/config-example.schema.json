{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "config-example",
  "type": "object",
  "x-ui": {
    "name": "Config Example",
    "description": "Annotated code block with numbered callouts",
    "icon": "M4 2v12M8 2v12M2 7h8",
    "display": {
      "color": "var(--type-text)",
      "layout": "prose",
      "summaryField": "title",
      "summaryFallback": "Code example"
    }
  },
  "properties": {
    "title": {
      "type": "string",
      "x-ui": { "label": "Title", "order": 1 }
    },
    "language": {
      "type": "string",
      "enum": ["json", "yaml", "javascript", "typescript", "bash", "csharp"],
      "default": "json",
      "x-ui": { "label": "Language", "order": 2 }
    },
    "code": {
      "type": "string",
      "x-ui": { "label": "Code", "widget": "textarea", "order": 3 }
    },
    "annotations": {
      "type": "array",
      "x-ui": { "label": "Annotations", "order": 4 },
      "items": {
        "type": "object",
        "properties": {
          "line": { "type": "number", "x-ui": { "label": "Line number" } },
          "text": { "type": "string", "x-ui": { "label": "Annotation text" } }
        },
        "required": ["line", "text"]
      }
    }
  },
  "required": ["code"]
}
