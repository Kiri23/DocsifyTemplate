{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "entity-schema",
  "type": "object",
  "x-ui": {
    "name": "Data Model",
    "description": "Describe a thing in your system and its properties",
    "icon": "M3 2h10v12H3zM6 5h4M6 8h4M6 11h3",
    "display": {
      "color": "var(--type-schema)",
      "layout": "entity",
      "summaryField": "name",
      "summaryFallback": "Unnamed model",
      "countField": "fields",
      "countLabel": "properties"
    }
  },
  "properties": {
    "name": {
      "type": "string",
      "default": "Entity",
      "x-ui": { "label": "Name", "order": 1 }
    },
    "parent": {
      "type": "string",
      "x-ui": { "label": "Inherits from", "order": 2 }
    },
    "fields": {
      "type": "array",
      "x-ui": { "label": "Properties", "order": 3 },
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "x-ui": { "label": "Name" } },
          "type": { "type": "string", "default": "string", "x-ui": { "label": "Type" } },
          "required": { "type": "boolean", "default": false, "x-ui": { "label": "Required" } },
          "description": { "type": "string", "x-ui": { "label": "Description" } }
        },
        "required": ["name"]
      }
    }
  },
  "required": ["name", "fields"]
}
