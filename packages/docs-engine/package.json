{
  "name": "docs-engine",
  "version": "0.1.8",
  "description": "Framework-agnostic docs intelligence engine: YAML components, Custom Elements, serializers, adapters for Docsify and Astro",
  "main": "dist/docs-engine.esm.js",
  "module": "dist/docs-engine.esm.js",
  "exports": {
    ".":              { "import": "./dist/docs-engine.esm.js" },
    "./docsify":      { "import": "./dist/docsify-adapter.js" },
    "./docsify/esm":  { "import": "./dist/docsify-adapter.esm.js" },
    "./style":        "./dist/theme.css"
  },
  "files": [
    "dist",
    "src/**/*.js",
    "src/**/*.json",
    "src/serializers/README.md",
    "!src/adapters/docsify/export/pandoc.wasm",
    "!src/adapters/docsify/export/pandoc.wasm.bak",
    "!src/vendor"
  ],
  "scripts": {
    "build": "node build.mjs",
    "build:watch": "node build.mjs --watch"
  },
  "peerDependencies": {
    "preact": ">=10",
    "preact-custom-element": ">=4",
    "@preact/signals": ">=1",
    "htm": ">=3",
    "unified": ">=11",
    "remark-parse": ">=11",
    "unist-util-visit": ">=5",
    "js-yaml": ">=4"
  },
  "peerDependenciesMeta": {
    "preact":                { "optional": true },
    "preact-custom-element": { "optional": true },
    "@preact/signals":       { "optional": true },
    "htm":                   { "optional": true },
    "unified":               { "optional": true },
    "remark-parse":          { "optional": true },
    "unist-util-visit":      { "optional": true },
    "js-yaml":               { "optional": true }
  },
  "devDependencies": {
    "@preact/signals": "^1.3.0",
    "esbuild": "^0.25.0",
    "htm": "^3.1.1",
    "js-yaml": "^4.1.1",
    "preact": "^10.29.1",
    "preact-custom-element": "^4.6.0",
    "preact-render-to-string": "^6.6.7",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kiri23/DocsifyTemplate.git",
    "directory": "packages/docs-engine"
  },
  "homepage": "https://github.com/Kiri23/DocsifyTemplate#readme",
  "license": "ISC",
  "type": "module"
}
