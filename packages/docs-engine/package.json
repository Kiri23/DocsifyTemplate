{
  "name": "docs-engine",
  "version": "0.1.0",
  "description": "Framework-agnostic docs intelligence engine: YAML components, Custom Elements, serializers, adapters for Docsify and Astro",
  "main": "dist/docsify-kiri.min.js",
  "exports": {
    ".":                   "./src/index.js",
    "./renderers/preact":  "./src/renderers/preact.js",
    "./components":        "./src/components/index.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node build.mjs",
    "build:watch": "node build.mjs --watch"
  },
  "peerDependencies": {
    "js-yaml": ">=4"
  },
  "peerDependenciesMeta": {
    "js-yaml": { "optional": true }
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "htm": "^3.1.1",
    "js-yaml": "^4.1.1",
    "preact": "^10.29.1",
    "preact-render-to-string": "^6.6.7",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kiri23/DocsifyTemplate.git",
    "directory": "packages/docs-engine"
  },
  "homepage": "https://github.com/Kiri23/DocsifyTemplate#readme",
  "license": "ISC",
  "type": "module"
}
